<h1>履歴一覧表示</h1>
<table class="table">
  <thead>
    <tr>
      <th>原文</th>
      <th>訳文</th>
    </tr>
  </thead>
  <tbody>
    <% if @translations.empty? %>
      <tr>
        <td>翻訳履歴はありません。</td>
      </tr>
    <% else %>
      <% @translations.each do |t| %>
        <tr>
          <td><%= t.input_text %></td>
          <td><%= t.translated_text %></td>
        </tr>
      <% end %>
    <% end %>
  </tbody>
</table>
<div class="mt-4">
  <%= link_to "新しく翻訳する", new_translation_path, class: "btn btn-primary" %>
  <%= link_to "topへ戻る", root_path, class: "btn btn-secondary" %>
</div>