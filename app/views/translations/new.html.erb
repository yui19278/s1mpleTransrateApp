<h1>翻訳画面</h1>
<%= form_with(model: @translation, url: translations_path, local: true) do |f| %>
  <% if @translation.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @translation.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="mb-3">
    <%= f.label :input_text, "テキストを入力", class: "form-label" %>
    <%= f.text_area :input_text, class: "form-control", rows: 5, placeholder: "例) こんにちわ" %>
  </div>
  <div class="actions">
    <%= f.submit "翻訳する", class: "btn btn-primary" %>
  </div>
<% end %>
<div class="mt-3">
  <%= link_to "履歴に戻る", translations_path %>
</div>